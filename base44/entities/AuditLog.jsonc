    },
    "action": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "detail": {
      "type": "string"
    },
    "ip_address": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
